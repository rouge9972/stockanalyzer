# ── Which market-data backend is PRIMARY ──────────────────────────────
# finnhub = Finnhub primary + Yahoo fallback (recommended for the live link)
# yahoo   = Yahoo only (personal-use mode)
DATA_SOURCE=finnhub

# Finnhub API key (free tier). Required only when DATA_SOURCE=finnhub.
# Get one at https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key_here

# Groq API key powers the AI analysis + portfolio endpoints.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional cache TTLs in seconds (defaults shown)
# CACHE_TTL_INFO=300
# CACHE_TTL_HIST=300
# CACHE_TTL_NEWS=600
# CACHE_TTL_SEARCH=600
