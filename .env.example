# Groq API key powers the AI analysis + portfolio endpoints.
# Get a free key at https://console.groq.com/keys
# The market-data endpoints work without it.
GROQ_API_KEY=your_groq_api_key_here

# Optional cache TTLs in seconds (defaults shown)
# CACHE_TTL_INFO=300
# CACHE_TTL_HIST=300
# CACHE_TTL_NEWS=600
# CACHE_TTL_SEARCH=600
